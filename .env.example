# =============================================================================
# LetsLearnOS environment configuration example
# Copy to .env and adjust. Never commit a real .env.
# =============================================================================

# --- Server -------------------------------------------------------------------
PORT=8765
# APP_ENV=kiosk enables static frontend serving and SQLite defaults on-device.
APP_ENV=development
NODE_ENV=development

# Optional HMAC key for short-lived parent-admin bearer tokens. If unset, the
# backend generates an in-memory key and admin tokens expire on restart.
# ADMIN_AUTH_SECRET=

# --- Database -----------------------------------------------------------------
# Development with Postgres:
#   DATABASE_URL=postgres://user:password@localhost:5432/letslearnos
# Standalone kiosk with SQLite:
#   DATABASE_URL=sqlite:/home/kids/.local/share/letslearnos/db.sqlite
DATABASE_URL=postgres://localhost:5432/letslearnos
# DB_DRIVER=

# --- Optional OpenAI narration ------------------------------------------------
# Create an API key in the OpenAI API dashboard. API usage and billing are
# separate from a ChatGPT subscription. The key is read by the backend only.
# Leave this blank for fully offline browser SpeechSynthesis narration.
OPENAI_API_KEY=

# Advanced deployments may inject a short-lived workload-identity token instead
# of an API key. Do not save an expiring token in this file.
# OPENAI_ACCESS_TOKEN=

# Current default from the OpenAI text-to-speech guide.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OpenAI recommends marin or cedar for best quality.
OPENAI_TTS_VOICE=marin
# Optional separate voice for Spanish; defaults to OPENAI_TTS_VOICE.
# OPENAI_TTS_VOICE_ES=marin

# Optional speaking-style prompts. Do not place child names or profile data in
# these values.
# OPENAI_TTS_INSTRUCTIONS=Speak warmly, clearly, and encouragingly for a young learner.
# OPENAI_TTS_INSTRUCTIONS_ES=Speak in clear, friendly Spanish at a comfortable pace for a young learner.

# Optional OpenAI organization/project routing and local disk-cache location.
# OPENAI_ORGANIZATION_ID=
# OPENAI_PROJECT_ID=
# OPENAI_TTS_CACHE_DIR=/home/kids/.local/share/letslearnos/openai-tts
